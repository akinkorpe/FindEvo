# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# OpenRouter (OpenAI-compatible API)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Reddit ingestion via Apify (production). Without APIFY_TOKEN the code
# falls back to anonymous public JSON — fine for local dev, blocked by
# Reddit on Vercel/datacenter IPs.
APIFY_TOKEN=
APIFY_ACTOR_ID=trudax/reddit-scraper-lite
REDDIT_USER_AGENT=web:findevo:1.0.0 (by /u/findevo_app)

# Lemon Squeezy billing. Without LEMONSQUEEZY_API_KEY the checkout/webhook
# routes return 503 — local dev keeps working, the pricing page just can't
# start a real subscription.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
# Variant IDs from the Lemon Squeezy product page (one per plan tier).
# Only Starter is wired in the UI today; Growth/Pro variants are read by the
# webhook if they exist so we can flip them on without a code change.
LEMONSQUEEZY_VARIANT_STARTER_MONTHLY=
LEMONSQUEEZY_VARIANT_STARTER_YEARLY=
LEMONSQUEEZY_VARIANT_GROWTH_MONTHLY=
LEMONSQUEEZY_VARIANT_PRO_MONTHLY=

# Used for checkout redirect_url. Set to the prod origin in Vercel
# (e.g. https://gofindevo.com). Localhost is fine in dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000
